gemini:
  api_keys:
    - GEMINI_API_KEY_1
    - GEMINI_API_KEY_2
    - GEMINI_API_KEY_3
  model: gemini-2.5-flash
  request_timeout_seconds: 300
  temperature: 0

classification:
  batch_size: 75
  retry_attempts: 10
  request_delay_seconds: 5
  retry_backoff_seconds: 15
  max_backoff_seconds: 90
  max_requests_per_minute: 5

paths:
  classification_specification_md: references\classification_specification_v2.md
  narrative_specification_md: references\narrative_specification_v1.md
  issues_24_md: references\24_ta_masala.md
  laws_162_md: references\Qonunlar_taqsimoti.md
  reference_report_docx: references\Telegram_bo'yicha_haftalik_jadval_22_28_iyun.docx
  output_root: data

report_period:
  mode: auto
  explicit_start: null
  explicit_end: null
